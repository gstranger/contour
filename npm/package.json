{
  "name": "vecnet-wasm",
  "version": "0.1.0",
  "description": "WASM vector network engine for the browser",
  "type": "module",
  "module": "./pkg/index.js",
  "main": "./pkg/index.js",
  "types": "./pkg/index.d.ts",
  "exports": {
    ".": {
      "import": "./pkg/index.js",
      "types": "./pkg/index.d.ts"
    },
    "./simd": {
      "import": "./pkg/simd/index.js",
      "types": "./pkg/simd/index.d.ts"
    },
    "./threads": {
      "import": "./pkg/threads/index.js",
      "types": "./pkg/threads/index.d.ts"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "pkg",
    "README.md"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=16"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/gstranger/vecnet-wasm"
  },
  "homepage": "https://github.com/gstranger/vecnet-wasm#readme",
  "bugs": {
    "url": "https://github.com/gstranger/vecnet-wasm/issues"
  },
  "keywords": [
    "wasm",
    "webassembly",
    "vector",
    "graphics",
    "vector-network",
    "canvas"
  ],
  "author": "gstranger",
  "license": "MIT"
}
